#!/bin/sh
# agent-fleet state hook: invoked by an agent's lifecycle events with the
# event JSON on stdin; records this session's state as one file for the
# muster to merge. usage: hook <agent>
set -eu
dir="${XDG_STATE_HOME:-$HOME/.local/state}/agent-fleet"
mkdir -p "$dir"
in=$(cat)
# // empty: a missing/null field must fail validation, not become "null"
sid=$(printf '%s' "$in" | jq -r '.session_id // empty')
ev=$(printf '%s' "$in" | jq -r '.hook_event_name // empty')
case "$sid" in
    *[!A-Za-z0-9-]*|'') echo "hook: unusable session_id: $sid" >&2; exit 1 ;;
esac
case "$ev" in
    SessionStart|UserPromptSubmit)  state=working ;;
    Stop)                           state=waiting ;;
    Notification|PermissionRequest) state=needs-action ;;
    SessionEnd)                     rm -f "$dir/$sid.json"; exit 0 ;;
    *) echo "hook: unknown hook_event_name: $ev" >&2; exit 1 ;;
esac
# sessions outside tmux are out of fleet scope: no state file at all
[ -n "${TMUX_PANE:-}" ] || exit 0
pane=$(tmux display -p -t "$TMUX_PANE" '#S:#I.#P')
pane_id="$TMUX_PANE"
# host is informational; the muster stamps rows with the hosts-file alias
printf '%s' "$in" | jq \
    --arg agent "$1" --arg host "$(hostname)" \
    --arg pane "$pane" --arg pane_id "$pane_id" --arg state "$state" \
    '{session_id, agent: $agent, host: $host, pane: $pane,
      pane_id: $pane_id, cwd, state: $state, ts: now|floor}' \
    > "$dir/.$sid.$$"
mv "$dir/.$sid.$$" "$dir/$sid.json"
# actionable events ring the pane's bell: the alert flag rides tmux natively
# (through nested ssh clients too), and visiting the window acknowledges it.
# stateless per event; re-ringing an already-flagged window is idempotent.
case "$state" in
    waiting|needs-action) printf '\a' > "$(tmux display -p -t "$pane_id" '#{pane_tty}')" ;;
esac
