def screen(*lines):
    print("\033[2J\033[H", end="")
    print("\n\n" + "\n\n".join(f"{line:^88}" for line in lines), flush=True)


def record(path, seconds):
    blocks = round(seconds * RATE / FRAME)
    frames = []
    with sd.InputStream(samplerate=RATE, channels=1, dtype="int16",
                        blocksize=FRAME) as stream:
        for block in range(blocks):
            frame, _ = stream.read(FRAME)
            frames.append(frame.copy())
            remaining = seconds - (block + 1) * FRAME / RATE
            print(f"\r{max(0, remaining):4.1f} seconds remaining", end="", flush=True)
    print()
    audio = np.concatenate(frames)
    with wave.open(str(path), "wb") as output:
        output.setnchannels(1)
        output.setsampwidth(2)
        output.setframerate(RATE)
        output.writeframes(audio.tobytes())
    return int(np.abs(audio.astype(np.int32)).max()), len(audio) / RATE


def append(path, value):
    with path.open("a") as output:
        output.write(json.dumps(value, ensure_ascii=False) + "\n")
        output.flush()


def main():
    root = ROOT / datetime.now().strftime("%Y%m%d-%H%M%S")
    root.mkdir(parents=True)
    prompts = root / "prompts.jsonl"
    captures = root / "captures.jsonl"
    created = datetime.now(timezone.utc).isoformat()
    for number, (name, phrase, seconds, instruction) in enumerate(TRIALS, 1):
        append(prompts, {
            "trial": number, "file": f"{number:02}-{name}.wav",
            "text": phrase, "seconds": seconds, "instruction": instruction,
            "created": created,
        })

    screen("ALAN TRANSCRIPTION STUDY", f"{len(TRIALS)} recordings · about 8 minutes",
           "Each prompt appears before a 3–2–1 countdown",
           "Begin speaking when the screen says NOW",
           "Recording stops automatically when its displayed timer reaches zero",
           "You do not need to press anything between recordings",
           "Exact prompts have already been saved",
           "Press Enter once to begin · Ctrl-C cancels safely")
    input()
    for number, (name, phrase, seconds, instruction) in enumerate(TRIALS, 1):
        screen(f"RECORDING {number} OF {len(TRIALS)}", "GET READY", instruction,
               phrase or "[NO SPEECH]")
        time.sleep(3)
        for count in (3, 2, 1):
            screen(f"RECORDING {number} OF {len(TRIALS)}", instruction,
                   phrase or "[NO SPEECH]", str(count))
            time.sleep(0.7)
        screen(f"RECORDING {number} OF {len(TRIALS)}", instruction,
               phrase or "[NO SPEECH]", "NOW")
        filename = f"{number:02}-{name}.wav"
        peak, duration = record(root / filename, seconds)
        append(captures, {
            "trial": number, "file": filename, "captured": datetime.now(timezone.utc).isoformat(),
            "duration": duration, "peak": peak,
        })
        screen(f"CAPTURED {number} OF {len(TRIALS)}", phrase or "[NO SPEECH]",
               f"{duration:.1f} seconds · peak {peak}", "Next recording shortly")
        time.sleep(2)
    screen("COMPLETE", str(root), "The window will close in 15 seconds")
    time.sleep(15)


if __name__ == "__main__":
    main()
