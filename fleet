#!/usr/bin/python3
"""Awareness and switching for terminal AI-agent sessions in tmux."""

import json
import mmap
import os
import re
import shlex
import subprocess
import sys
import time
import urllib.request
from collections import deque
from dataclasses import dataclass
from datetime import datetime
from pathlib import Path

CONFIG = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "agent-fleet"
RUNTIME = Path(os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}"))
SSH_AGENT_SOCKET = RUNTIME / "gnupg/S.gpg-agent.ssh"
CADENCE = 2
USAGE_CADENCE = 300
MUSTER_SOCKET = RUNTIME / "agent-fleet-muster.sock"
NAME_RE = re.compile(r"^[A-Za-z0-9_-]+$")
AGENT_CMDS = {"claude": "claude", "codex": "codex"}
URGENCY = {"needs-action": 0, "waiting": 1, "working": 2}
AGENT_ICONS = {"claude": "\ue861", "codex": "\ue7cf"}
STATE_ICONS = {"needs-action": "\uf071", "waiting": "\uf252", "working": "\uf013"}
HOST_ICONS = {
    "lovelace": "\uf121",
    "newton": "\uf5d1",
    "turing": "\uf2db",
    "boltzmann": "\uf5d2",
    "noether": "\uf534",
}
# Terminal-set titles require #{q:} and shlex; delimiters are not safe.
PANE_FMT = ("#{q:session_name} #{q:window_id} #{window_index} #{q:pane_id} "
            "#{pane_pid} #{q:pane_current_command} "
            "#{q:pane_current_path} #{q:pane_title}")


def hosts():
    lines = (CONFIG / "hosts").read_text().split()
    if not lines:
        sys.exit(f"fleet: {CONFIG / 'hosts'} is empty")
    return lines


def flagship():
    return hosts()[0]


def run(argv, **kw):
    return subprocess.run(argv, text=True, capture_output=True, **kw)


def sh(host, script):
    argv = (["sh", "-c", script] if host == flagship()
            else ["ssh", host, "sh -c " + shlex.quote(script)])
    r = run(argv)
    if r.stderr:
        print(r.stderr, end="", file=sys.stderr)
    return r


def tmux(host, *args):
    argv = ["tmux", *args]
    if host != flagship():
        # A remote zsh expands tmux's =targets.
        cmd = "tmux " + " ".join(shlex.quote(a) for a in args)
        argv = ["ssh", host, "sh -c " + shlex.quote(cmd)]
    r = run(argv)
    if r.returncode != 0:
        sys.exit(f"fleet: tmux {' '.join(args)} on {host}: {r.stderr.strip()}")
    if r.stderr:  # no stderr suppression anywhere, success included
        print(r.stderr, end="", file=sys.stderr)
    return r.stdout


def tmux_batched(host, cmds):
    # tmux clients reject command strings around 16 KiB.
    chunk, size = [], 0
    for c in cmds:
        n = sum(len(a) + 1 for a in c) + 2
        if chunk and size + n > 8000:
            tmux(host, *[a for cc in chunk for a in cc + [";"]][:-1])
            chunk, size = [], 0
        chunk.append(c)
        size += n
    if chunk:
        tmux(host, *[a for cc in chunk for a in cc + [";"]][:-1])


def absent(host, name):
    argv = ["tmux", "has-session", "-t", f"={name}"]
    if host != flagship():
        argv = ["ssh", host, "tmux has-session -t " + shlex.quote(f"={name}")]
    r = run(argv)
    if not r.returncode:
        return False
    if r.returncode == 1 and ("can't find session" in r.stderr
                              or "no server running" in r.stderr):
        return True
    sys.exit(f"fleet: tmux has-session {name} on {host}: {r.stderr.strip()}")


def muster_push(action):
    if not MUSTER_SOCKET.exists():
        return
    r = run(["curl", "--silent", "--show-error", "--unix-socket",
             str(MUSTER_SOCKET), "-X", "POST", "-d", action, "http://localhost"])
    if r.returncode and MUSTER_SOCKET.exists():
        sys.exit(f"fleet: muster socket: {r.stderr.strip()}")


def check_screen(screen):
    if not NAME_RE.match(screen):
        sys.exit(f"fleet: screen names are [A-Za-z0-9_-]+, got {screen!r}")
    return screen


def selected_screen(args):
    if args.screen:
        return check_screen(args.screen)
    screen = tmux(flagship(), "show-option", "-gqv", "@fleet_focused_station").strip()
    return check_screen(screen or "main")


CLAUDE = Path.home() / ".claude/projects"
CODEX = Path.home() / ".codex/sessions"


@dataclass
class Session:
    agent: str
    session_id: str
    path: Path
    mtime: float

    def cwd(self):
        for d in events(self):
            if self.agent == "claude" and "cwd" in d:
                return d["cwd"]
            if self.agent == "codex" and d.get("type") == "session_meta":
                return d["payload"]["cwd"]
        return ""


def sessions(agent=None):
    out = []
    if agent in (None, "claude"):
        for f in CLAUDE.glob("*/*.jsonl"):
            out.append(session_at("claude", f))
    if agent in (None, "codex"):
        for f in CODEX.glob("*/*/*/rollout-*.jsonl"):
            out.append(session_at("codex", f))
    return sorted(out, key=lambda s: -s.mtime)


def session_at(agent, path):
    p = Path(path)
    return Session(agent, p.stem[-36:], p, p.stat().st_mtime)


def event_time(d):
    return datetime.fromisoformat(d["timestamp"].replace("Z", "+00:00")).timestamp()


def last_event_time(path):
    for d in reverse_events(path):
        if "timestamp" in d:
            return int(event_time(d))
    raise ValueError(f"no timestamped events in {path}")


def reverse_events(path):
    with open(path, "rb") as f, mmap.mmap(f.fileno(), 0, access=mmap.ACCESS_READ) as data:
        end = len(data)
        while end:
            start = data.rfind(b"\n", 0, end)
            line = data[start + 1:end]
            end = start
            if line:
                yield json.loads(line)


def account_usage(agent):
    r = run(["fleet-usage", agent])
    if r.returncode:
        raise OSError(r.stderr.strip())
    return r.stdout.strip()


def live_state(s):
    boundary, summary, updated = "task_complete", "", None
    for d in events(s):
        if "timestamp" in d:
            updated = event_time(d)
        if d.get("type") == "event_msg":
            t = d["payload"]["type"]
            if t in ("task_started", "task_complete"):
                boundary = t
            elif t == "agent_message":
                summary = d["payload"]["message"]
    return ("working" if boundary == "task_started" else "waiting"), summary, int(updated)


def events(s):
    with open(s.path) as fh:
        for line in fh:
            if line.strip():
                yield json.loads(line)


def texts(s, role="assistant", n=1):
    keep = deque(maxlen=n)
    for d in events(s):
        if s.agent == "claude" and d.get("type") == role:
            blocks = d["message"]["content"]
            if isinstance(blocks, str):
                keep.append(blocks)
            else:
                text = "\n".join(b["text"] for b in blocks
                                 if b.get("type") == "text")
                if text:
                    keep.append(text)
        elif s.agent == "codex" and d.get("type") == "event_msg":
            want = {"assistant": "agent_message", "user": "user_message"}[role]
            if d["payload"]["type"] == want:
                keep.append(d["payload"]["message"])
    return list(keep)


def resolve_log(prefix, agent=None):
    all_ = sessions(agent)
    if not all_:
        sys.exit("fleet: no sessions")
    if not prefix:
        return all_[0]
    matches = [s for s in all_ if s.session_id.startswith(prefix)]
    if not matches:
        sys.exit(f"fleet: no session matches {prefix!r}")
    if len(matches) > 1 and len({s.session_id for s in matches}) > 1:
        sys.exit(f"fleet: {prefix!r} is ambiguous "
                 f"({len(matches)} sessions)")
    return matches[0]


def age(t):
    d = int(time.time() - t)
    for unit, span in (("d", 86400), ("h", 3600), ("m", 60)):
        if d >= span:
            return f"{d // span}{unit}"
    return f"{d}s"


def info(s):
    models, first_ts, counts = [], None, {}
    branch = version = None
    for d in events(s):
        ts = d.get("timestamp")
        first_ts = first_ts or ts
        if s.agent == "claude":
            counts[d.get("type")] = counts.get(d.get("type"), 0) + 1
            m = d.get("message", {}).get("model") if d.get("type") == "assistant" else None
            branch = d.get("gitBranch") or branch
            version = d.get("version") or version
        else:
            t = d.get("payload", {}).get("type") or d.get("type")
            counts[t] = counts.get(t, 0) + 1
            m = d["payload"].get("model") if d.get("type") == "turn_context" else None
            if d.get("type") == "session_meta":
                version = d["payload"].get("cli_version")
        if m and (not models or models[-1] != m):
            models.append(m)
    return dict(agent=s.agent, session_id=s.session_id, path=str(s.path),
                cwd=s.cwd(), started=first_ts,
                last=time.strftime("%Y-%m-%dT%H:%M:%S", time.localtime(s.mtime)),
                model=models[-1] if models else None, models=models,
                branch=branch, cli_version=version,
                turns=counts.get("user", 0) + counts.get("user_message", 0),
                counts=counts)


def cmd_info(args):
    print(json.dumps(info(resolve_log(args.session, args.agent)), indent=2))


def cmd_list(args):
    for s in sessions(args.agent)[: args.n]:
        print(f"{s.agent:<7}{s.session_id[:8]}  {age(s.mtime):>4}  {s.cwd()}")


def cmd_latest(args):
    s = resolve_log(args.session, args.agent)
    for t in texts(s, role=args.role, n=args.n):
        print(t)


def child_map():
    kids = {}
    for line in run(["ps", "-eo", "pid=,ppid="]).stdout.splitlines():
        pid, ppid = (int(x) for x in line.split())
        kids.setdefault(ppid, []).append(pid)
    return kids


def descendants(pid, kids):
    seen, stack = [], [pid]
    while stack:
        for k in kids.get(stack.pop(), []):
            seen.append(k)
            stack.append(k)
    return seen


def open_transcript(tree, needle):
    for p in tree:
        try:
            entries = os.listdir(f"/proc/{p}/fd")
        except OSError:
            continue
        for fd in entries:
            try:
                target = os.readlink(f"/proc/{p}/fd/{fd}")
            except OSError:
                continue
            if needle in target:
                return target
    return None


def claude_agents():
    r = run(["claude", "agents", "--json"])
    r.check_returncode()
    return {x["pid"]: x for x in json.loads(r.stdout)}


def claude_status(entry, title):
    if entry.get("state") == "blocked":
        return "needs-action"
    if entry["status"] == "idle" or title.startswith("✳"):
        return "waiting"
    return "working"


def cmd_poll(args):
    cmd_agent = {cmd: agent for agent, cmd in AGENT_CMDS.items()}
    agents = claude_agents()
    kids = child_map()
    r = run(["tmux", "list-panes", "-a", "-F", PANE_FMT])
    if r.returncode:
        sys.exit(f"fleet: list-panes: {r.stderr.strip()}")
    rows = []
    for line in r.stdout.splitlines():
        sess, win, widx, pid, ppid, cmd, cwd, title = shlex.split(line)
        agent = cmd_agent.get(cmd)
        if agent is None or "@" in sess:
            continue
        tree = [int(ppid), *descendants(int(ppid), kids)]
        if agent == "claude":
            entry = next(agents[p] for p in tree if p in agents)
            state = claude_status(entry, title)
            f = CLAUDE / entry["cwd"].replace("/", "-").replace(".", "-") \
                / f"{entry['sessionId']}.jsonl"
            ts = last_event_time(f) if f.exists() else 0
        elif agent == "codex":
            roll = open_transcript(tree, "rollout-")
            s = session_at("codex", roll)
            state, title, ts = live_state(s)
        else:
            sys.exit(f"fleet: no poll reader for agent {agent!r}")
        title = " ".join(title.split())
        rows.append(dict(session=sess, win=win, window=int(widx), pane_id=pid,
                         agent=agent, state=state, title=title, cwd=cwd, ts=ts))
    print(json.dumps(rows))


def poll(host):
    argv = ["fleet", "_poll"] if host == flagship() else ["ssh", host, "fleet _poll"]
    r = run(argv)
    if r.stderr:
        print(r.stderr, end="", file=sys.stderr)
    if r.returncode:
        if r.returncode == 255:
            return None
        sys.exit(f"fleet: _poll on {host} failed: {r.stderr.strip()}")
    return json.loads(r.stdout)


def merge():
    pane_rows, unreachable = [], []
    for host in hosts():
        got = poll(host)
        if got is None:
            unreachable.append(host)
            continue
        for p in got:
            pane_rows.append(dict(p, host=host))
    rows = {}
    for p in sorted(pane_rows, key=lambda p: p["window"]):
        key = (p["host"], p["win"])
        g = rows.get(key)
        if g is None:
            rows[key] = dict(p, count=1)
            continue
        g["count"] += 1
        g["ts"] = max(g["ts"], p["ts"])
        g["pane_id"] = None
        if URGENCY[p["state"]] < URGENCY[g["state"]]:
            g.update(state=p["state"], cwd=p["cwd"], title=p["title"],
                     agent=p["agent"])
    ordered = sorted(rows.values(), key=lambda r: (URGENCY[r["state"]], -r["ts"]))
    return ordered, unreachable


def fleet_inventory():
    fs = "fleet@main"
    have = {}
    fmt = ("idx=#{window_index} wid=#{q:window_id} host=#{q:@fleet_host} "
           "win=#{q:@fleet_win} src=#{q:@fleet_src} state=#{q:@fleet_state} "
           "changed=#{q:@fleet_state_changed}")
    for line in tmux(flagship(), "list-windows", "-t", f"={fs}", "-F", fmt).splitlines():
        d = dict(x.partition("=")[::2] for x in shlex.split(line))
        if d["idx"] == "0":
            continue
        if not d["host"] or not d["win"]:
            sys.exit(f"fleet: unstamped window {fs}:{d['idx']} — not fleet's, refusing to own it")
        key = (d["host"], d["win"])
        if key in have:
            sys.exit(f"fleet: windows {fs}:{have[key]['idx']} and {fs}:{d['idx']} "
                     f"both claim {d['host']}:{d['win']}")
        have[key] = d
    return have


def group_selections():
    selected = {}
    fmt = ("session=#{q:session_name} group=#{q:session_group} "
           "win=#{window_id}")
    for line in tmux(flagship(), "list-sessions", "-F", fmt).splitlines():
        d = dict(x.partition("=")[::2] for x in shlex.split(line))
        if d["group"] == "fleet@main":
            selected[d["session"]] = d["win"]
    return selected


def restore_group_selections(selected):
    current = group_selections()
    live = set(tmux(flagship(), "list-windows", "-t", "=fleet@main",
                    "-F", "#{window_id}").splitlines())
    commands = [["select-window", "-t", f"={session}:{win}"]
                for session, win in selected.items()
                if win in live and current.get(session) != win]
    if commands:
        tmux_batched(flagship(), commands)


def remove_missing(have, want, unreachable):
    fs = "fleet@main"
    for (host, win), w in list(have.items()):
        r = want.get((host, win))
        src_ok = r is not None and (w["src"] == "" if r["host"] == flagship()
                                    else w["src"] == r["session"])
        if src_ok:
            continue
        if host in unreachable:
            continue
        if host == flagship():
            tmux(flagship(), "unlink-window", "-t", f"={fs}:{w['idx']}")
        else:
            tmux(flagship(), "kill-window", "-t", f"={fs}:{w['idx']}")
        del have[(host, win)]


def ordering_frozen():
    for line in tmux(flagship(), "list-clients", "-F",
                     "#{q:session_name} #{client_key_table}").splitlines():
        session, table = shlex.split(line)
        if session.startswith("fleet@") and session != "fleet@muster" and table == "fleet":
            return True
    return False


def number_rows(rows, have, want, frozen):
    fs = "fleet@main"
    n, stale_num = 0, {}
    if frozen:
        n = max((int(w["idx"]) for w in have.values()), default=0)
        for r in rows:
            w = have.get((r["host"], r["win"]))
            r["num"] = int(w["idx"]) if w else (n := n + 1)
        for k in set(have) - set(want):
            stale_num[k] = int(have[k]["idx"])
    else:
        order = {}
        for r in rows:
            n += 1
            order[(r["host"], r["win"])] = r["num"] = n
        for k in sorted(set(have) - set(want), key=lambda k: int(have[k]["idx"])):
            n += 1
            order[k] = stale_num[k] = n
        cur = tmux(flagship(), "display", "-p", "-t", f"={fs}:",
                   "#{window_id}").strip()
        moves, land = [], []
        for k, num in order.items():
            w = have.get(k)
            if w and int(w["idx"]) != num:
                d = [] if w["wid"] == cur else ["-d"]
                moves.append(["move-window", *d, "-s", f"{fs}:{w['idx']}",
                              "-t", f"{fs}:{1000 + num}"])
                land.append(["move-window", *d, "-s", f"{fs}:{1000 + num}",
                             "-t", f"{fs}:{num}"])
        if moves:
            tmux_batched(flagship(), moves + land)
    return stale_num


def create_rows(rows, have):
    fs = "fleet@main"
    want = {(r["host"], r["win"]): r for r in rows}
    for (host, win), r in want.items():
        if (host, win) in have:
            continue
        ident = ["set-option", "-w", "-t", f"{fs}:{r['num']}", "@fleet_host", host,
                 ";", "set-option", "-w", "-t", f"{fs}:{r['num']}", "@fleet_win", win]
        if host == flagship():
            tmux(flagship(), "link-window", "-d", "-s", win, "-t", f"={fs}:{r['num']}",
                 ";", *ident)
        else:
            attach = ("exec tmux -u attach-session -t "
                      + shlex.quote("=" + r["session"]))
            tmux(flagship(), "new-window", "-d", "-t", f"={fs}:{r['num']}",
                 "-n", r["session"],
                 f"exec ssh -t {shlex.quote(host)} "
                 + shlex.quote("exec sh -c " + shlex.quote(attach)),
                 ";", *ident,
                 ";", "set-option", "-w", "-t", f"{fs}:{r['num']}",
                 "@fleet_src", r["session"])


def stamp_rows(rows, have, stale_num, now):
    fs = "fleet@main"
    stamps = []
    for r in rows:
        old = have.get((r["host"], r["win"]))
        changed = (old["changed"] if old and old["state"] == r["state"]
                   and old["changed"] else str(now))
        r["state_changed"] = int(changed)
        for opt, val in dict(host=r["host"], win=r["win"], session=r["session"],
                             window=str(r["window"]), pane=r["pane_id"] or "",
                             agent=r["agent"], state=r["state"], state_changed=changed,
                             count=str(r["count"]), ts=str(r["ts"]),
                             num=str(r["num"]), cwd=r["cwd"],
                             name=f"{r['session']}:{r['window']}",
                             title=r["title"], stale="").items():
            stamps.append(["set-option", "-w", "-t", f"{fs}:{r['num']}",
                           f"@fleet_{opt}", val])
    for k, num in stale_num.items():
        stamps.append(["set-option", "-w", "-t", f"{fs}:{num}",
                       "@fleet_stale", "1"])
        stamps.append(["set-option", "-w", "-t", f"{fs}:{num}",
                       "@fleet_num", str(num)])
    if stamps:
        tmux_batched(flagship(), stamps)


def reconcile(rows, unreachable, now):
    selected = group_selections()
    have = fleet_inventory()
    want = {(r["host"], r["win"]): r for r in rows}
    remove_missing(have, want, unreachable)
    frozen = ordering_frozen()
    stale_num = number_rows(rows, have, want, frozen)
    create_rows(rows, have)
    stamp_rows(rows, have, stale_num, now)
    restore_group_selections(selected)
    return frozen


def manifest_write():
    now = int(time.time())
    rows, unreachable = merge()
    frozen = reconcile(rows, unreachable, now)
    usage_ts = tmux(flagship(), "show-option", "-qv", "-t", "fleet@main",
                    "@fleet_usage_ts").strip()
    if not usage_ts or now - int(usage_ts) >= USAGE_CADENCE:
        usage = {}
        for agent in ("claude", "codex"):
            try:
                usage[agent] = account_usage(agent)
            except OSError as e:
                usage[agent] = f"unavailable: {e}"
        tmux(flagship(), "set-option", "-t", "fleet@main", "@fleet_claude_usage",
             usage["claude"], ";", "set-option", "-t", "fleet@main",
             "@fleet_codex_usage", usage["codex"], ";", "set-option", "-t",
             "fleet@main", "@fleet_usage_ts", str(now))
    tmux(flagship(), "set-option", "-t", "fleet@main", "@fleet_unreachable",
         json.dumps(unreachable), ";", "set-option", "-t", "fleet@main",
         "@fleet_snapshot_ts", str(now), ";", "set-option", "-t", "fleet@main",
         "@fleet_frozen", "1" if frozen else "")
    muster_push("reload(fleet muster --rows)")
    return manifest()


def manifest():
    fmt = ("index=#{window_index} host=#{q:@fleet_host} win=#{q:@fleet_win} "
           "session=#{q:@fleet_session} window=#{q:@fleet_window} "
           "pane=#{q:@fleet_pane} agent=#{q:@fleet_agent} "
           "state=#{q:@fleet_state} changed=#{q:@fleet_state_changed} "
           "count=#{q:@fleet_count} ts=#{q:@fleet_ts} "
           "cwd=#{q:@fleet_cwd} title=#{q:@fleet_title} "
           "stale=#{q:@fleet_stale} snapshot_ts=#{q:@fleet_snapshot_ts} "
           "unreachable=#{q:@fleet_unreachable} frozen=#{q:@fleet_frozen} "
           "claude_usage=#{q:@fleet_claude_usage} codex_usage=#{q:@fleet_codex_usage}")
    lines = tmux(flagship(), "list-windows", "-t", "=fleet@main", "-F", fmt).splitlines()
    parsed = [dict(x.partition("=")[::2] for x in shlex.split(line)) for line in lines]
    rows = []
    for d in parsed:
        if d["index"] == "0" or d["stale"]:
            continue
        rows.append(dict(host=d["host"], win=d["win"], session=d["session"],
                         window=int(d["window"]), pane_id=d["pane"] or None,
                         agent=d["agent"], state=d["state"], count=int(d["count"]),
                         state_changed=int(d["changed"]), ts=int(d["ts"]),
                         cwd=d["cwd"], title=d["title"],
                         num=int(d["index"])))
    return dict(snapshot_ts=int(parsed[0]["snapshot_ts"]), rows=rows,
                unreachable=json.loads(parsed[0]["unreachable"]),
                frozen=bool(parsed[0]["frozen"]),
                claude_usage=parsed[0]["claude_usage"],
                codex_usage=parsed[0]["codex_usage"])


COLOR = {"needs-action": "\033[1;31m", "waiting": "\033[33m", "working": "\033[32m"}


def cmd_muster(args):
    if args.write:
        snap = manifest_write()
    else:
        snap = manifest()
    if args.rows:
        return muster_rows(snap)
    c = (lambda code, s: f"{code}{s}\033[0m") if args.color else (lambda code, s: s)
    cur = tuple(shlex.split(tmux(flagship(), "display", "-p", "-t", "=fleet@main:",
                                 "#{q:@fleet_host} #{q:@fleet_win}")))
    out = []
    age = int(time.time()) - snap["snapshot_ts"]
    if age > CADENCE:
        out.append(c("\033[2m", f"age {age}s"))
    if snap["frozen"]:
        out.append(c("\033[35m", "CONN — ordering held"))
    for host in snap["unreachable"]:
        out.append(c("\033[1;31m", f"{host} unreachable"))
    for r in snap["rows"]:
        name = f"{r['session']}:{r['window']}"
        if r["count"] > 1:
            name += f"×{r['count']}"
        body = f"{STATE_ICONS[r['state']]} {r['num']:>3} {name[:15]:<15} {HOST_ICONS[r['host']]}"
        out.append(c("\033[7m", body) if (r["host"], r["win"]) == cur else body)
    print("\n".join(out))


def muster_rows(snap):
    from collections import Counter
    stamp = time.strftime('%H:%M:%S', time.localtime(snap['snapshot_ts']))
    if snap["frozen"]:
        stamp += "  \033[35mCONN — ordering held\033[0m"
    out = [f"-\t-\t-\t\033[2m{stamp}\033[0m",
           f"-\t-\t-\t{AGENT_ICONS['claude']} {snap['claude_usage']}",
           f"-\t-\t-\t{AGENT_ICONS['codex']} {snap['codex_usage']}"]
    for host in snap["unreachable"]:
        out.append(f"{host}\t-\t-\t\033[1;31m{host} unreachable\033[0m")
    rows = snap["rows"]
    per_sess = Counter((r["host"], r["session"]) for r in rows)
    names = [(r["session"] if per_sess[(r["host"], r["session"])] == 1
              else f"{r['session']}:{r['window']}")
             + (f"×{r['count']}" if r["count"] > 1 else "") for r in rows]
    wn = max((len(n) for n in names), default=0)
    wc = max((len(Path(r["cwd"]).name) for r in rows), default=0)
    for r, name in zip(rows, names):
        line = (f"{COLOR[r['state']]}{STATE_ICONS[r['state']]} {name:<{wn + 2}}\033[0m"
                f"\033[2m{AGENT_ICONS[r['agent']]} {HOST_ICONS[r['host']]} "
                f"{Path(r['cwd']).name:<{wc + 1}}\033[0m{r['title']}")
        out.append(f"{r['host']}\t{r['win']}\t{r['num']}\t{line}")
    print("\n".join(out))


def cmd_muster_ui(args):
    os.environ["SSH_AUTH_SOCK"] = str(SSH_AGENT_SOCKET)
    os.execvp("fzf", [
