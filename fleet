#!/usr/bin/python3
"""agent-fleet: awareness and switching for terminal AI-agent sessions.

Agents are peers (claude, codex; more register in AGENT_CMDS and
agent_state). tmux is the fleet: fleet@main is a tmux session on the
flagship whose windows ARE the agent sessions — linked windows for
flagship rows, persistent ssh clients onto ship-side shadow sessions for
remote rows — so every motion (stepping, jumping, picking) is a native
tmux command and no external code sits in a keypress path. State is read
from what each agent already writes (no hook): the single writer
(`muster --write`, run under watch in fleet@main's muster window) polls
each host's pane inventory + per-agent state, groups panes into the
manifest, reconciles the fleet session's windows against it, and stamps
@fleet_* window options for tmux formats to render. fleet prints text
and invokes tmux.
"""

import fcntl
import json
import os
import re
import shlex
import subprocess
import sys
import time
import urllib.request
from pathlib import Path

CACHE = Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache")) / "agent-fleet"
CONFIG = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "agent-fleet"
CADENCE = 2  # the human-glance cadence
MUSTER_ADDR = "127.0.0.1:45871"
NAME_RE = re.compile(r"^[A-Za-z0-9_-]+$")
AGENT_CMDS = {"claude": "claude", "codex": "codex"}  # peers; pane_current_command → agent
URGENCY = {"needs-action": 0, "waiting": 1, "working": 2}
# every string field #{q:}-quoted and shlex-parsed, never tab separators
# (titles are terminal-set strings); the tmux client sanitises non-ASCII
# unless it runs under a UTF-8 locale, which non-interactive ssh lacks
PANE_FMT = ("#{q:session_name} #{q:window_id} #{window_index} #{q:pane_id} "
            "#{pane_pid} #{q:pane_current_command} "
            "#{q:pane_current_path} #{q:pane_title}")


def hosts():
    lines = (CONFIG / "hosts").read_text().split()
    if not lines:
        sys.exit(f"fleet: {CONFIG / 'hosts'} is empty")
    return lines  # lines[0] is the flagship's own alias


def flagship():
    return hosts()[0]


def run(argv, **kw):
    return subprocess.run(argv, text=True, capture_output=True, **kw)


def sh(host, script):
    # remote login shells may be zsh (whose nomatch aborts on empty globs):
    # scripts are written for sh semantics, so run them under sh everywhere
    argv = (["sh", "-c", script] if host == flagship()
            else ["ssh", host, "sh -c " + shlex.quote(script)])
    r = run(argv)
    if r.stderr:
        print(r.stderr, end="", file=sys.stderr)
    return r


def tmux(host, *args):
    argv = ["tmux", *args]
    if host != flagship():
        argv = ["ssh", host, "tmux " + " ".join(shlex.quote(a) for a in args)]
    r = run(argv)
    if r.returncode != 0:
        sys.exit(f"fleet: tmux {' '.join(args)} on {host}: {r.stderr.strip()}")
    if r.stderr:  # no stderr suppression anywhere, success included
        print(r.stderr, end="", file=sys.stderr)
    return r.stdout


def tmux_batched(host, cmds):
    # chained invocations hit the client's message size cap ("command too
    # long"): send in chunks well under it
    chunk, size = [], 0
    for c in cmds:
        n = sum(len(a) + 1 for a in c) + 2
        if chunk and size + n > 8000:
            tmux(host, *[a for cc in chunk for a in cc + [";"]][:-1])
            chunk, size = [], 0
        chunk.append(c)
        size += n
    if chunk:
        tmux(host, *[a for cc in chunk for a in cc + [";"]][:-1])


def write_atomic(path, text):
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(f".{path.name}.{os.getpid()}")
    tmp.write_text(text)
    tmp.replace(path)


def absent(name):
    # "can't find" is the verified wording for a missing session; anything
    # else is a boundary failure
    r = run(["tmux", "has-session", "-t", f"={name}"])
    if r.returncode and "can't find" not in r.stderr:
        sys.exit(f"fleet: tmux has-session {name}: {r.stderr.strip()}")
    return bool(r.returncode)


def muster_key():
    return Path(os.environ["XDG_RUNTIME_DIR"]) / "agent-fleet-muster.key"


def muster_push(action):
    # the muster column is an fzf --listen process; absent key file or a
    # refused connection mean no column is open — the only named skips
    kf = muster_key()
    if not kf.exists():
        return
    req = urllib.request.Request(
        f"http://{MUSTER_ADDR}", action.encode(),
        {"x-api-key": kf.read_text().split(": ", 1)[1].strip()})
    try:
        urllib.request.urlopen(req, timeout=1)
    except urllib.error.URLError as e:
        if not isinstance(e.reason, ConnectionRefusedError):
            raise


def check_screen(screen):
    if not NAME_RE.match(screen):
        sys.exit(f"fleet: screen names are [A-Za-z0-9_-]+, got {screen!r}")
    return screen


# ---------- the log book (transcript stores; import fleet to compose) ----------

from collections import deque
from dataclasses import dataclass

CLAUDE = Path.home() / ".claude/projects"
CODEX = Path.home() / ".codex/sessions"


@dataclass
class Session:
    agent: str
    session_id: str
    path: Path
    mtime: float

    def cwd(self):
        # the exact cwd lives in the transcript head, not the filename
        for d in events(self):
            if self.agent == "claude" and "cwd" in d:
                return d["cwd"]
            if self.agent == "codex" and d.get("type") == "session_meta":
                return d["payload"]["cwd"]
        return ""


def sessions(agent=None):
    """All local sessions, newest first. Cheap: filesystem metadata only."""
    out = []
    if agent in (None, "claude"):
        for f in CLAUDE.glob("*/*.jsonl"):
            out.append(session_at("claude", f))
    if agent in (None, "codex"):
        for f in CODEX.glob("*/*/*/rollout-*.jsonl"):
            out.append(session_at("codex", f))
    return sorted(out, key=lambda s: -s.mtime)


def session_at(agent, path):
    """A Session for a known transcript path (session id from the filename)."""
    p = Path(path)
    return Session(agent, p.stem[-36:], p, p.stat().st_mtime)



def live_state(s):
    """(state, summary) from a codex rollout's turn markers: task_started
    with no following task_complete is working, and the last agent_message
    is the nearest thing codex writes to a summary (it self-titles nothing)."""
    boundary, summary = "task_complete", ""
    for d in events(s):
        if d.get("type") == "event_msg":
            t = d["payload"]["type"]
            if t in ("task_started", "task_complete"):
                boundary = t
            elif t == "agent_message":
                summary = d["payload"]["message"]
    return ("working" if boundary == "task_started" else "waiting"), summary


def events(s):
    with open(s.path) as fh:
        for line in fh:
            if line.strip():
                yield json.loads(line)


def texts(s, role="assistant", n=1):
    """The last n message texts of a role, oldest first."""
    keep = deque(maxlen=n)
    for d in events(s):
        if s.agent == "claude" and d.get("type") == role:
            blocks = d["message"]["content"]
            if isinstance(blocks, str):
                keep.append(blocks)
            else:
                text = "\n".join(b["text"] for b in blocks
                                 if b.get("type") == "text")
                if text:
                    keep.append(text)
        elif s.agent == "codex" and d.get("type") == "event_msg":
            want = {"assistant": "agent_message", "user": "user_message"}[role]
            if d["payload"]["type"] == want:
                keep.append(d["payload"]["message"])
    return list(keep)


def resolve_log(prefix, agent=None):
    """A session by id prefix; no prefix means the most recent session."""
    all_ = sessions(agent)
    if not all_:
        sys.exit("fleet: no sessions")
    if not prefix:
        return all_[0]
    matches = [s for s in all_ if s.session_id.startswith(prefix)]
    if not matches:
        sys.exit(f"fleet: no session matches {prefix!r}")
    if len(matches) > 1 and len({s.session_id for s in matches}) > 1:
        sys.exit(f"fleet: {prefix!r} is ambiguous "
                 f"({len(matches)} sessions)")
    return matches[0]


def age(t):
    d = int(time.time() - t)
    for unit, span in (("d", 86400), ("h", 3600), ("m", 60)):
        if d >= span:
            return f"{d // span}{unit}"
    return f"{d}s"


def info(s):
    """Everything a transcript tells us, one pass: the complete view an
    agent shouldn't have to relearn."""
    models, first_ts, counts = [], None, {}
    branch = version = None
    for d in events(s):
        ts = d.get("timestamp")
        first_ts = first_ts or ts
        if s.agent == "claude":
            counts[d.get("type")] = counts.get(d.get("type"), 0) + 1
            m = d.get("message", {}).get("model") if d.get("type") == "assistant" else None
            branch = d.get("gitBranch") or branch
            version = d.get("version") or version
        else:
            t = d.get("payload", {}).get("type") or d.get("type")
            counts[t] = counts.get(t, 0) + 1
            m = d["payload"].get("model") if d.get("type") == "turn_context" else None
            if d.get("type") == "session_meta":
                version = d["payload"].get("cli_version")
        if m and (not models or models[-1] != m):
            models.append(m)
    return dict(agent=s.agent, session_id=s.session_id, path=str(s.path),
                cwd=s.cwd(), started=first_ts,
                last=time.strftime("%Y-%m-%dT%H:%M:%S", time.localtime(s.mtime)),
                model=models[-1] if models else None, models=models,
                branch=branch, cli_version=version,
                turns=counts.get("user", 0) + counts.get("user_message", 0),
                counts=counts)


def cmd_info(args):
    print(json.dumps(info(resolve_log(args.session, args.agent)), indent=2))


def cmd_list(args):
    for s in sessions(args.agent)[: args.n]:
        print(f"{s.agent:<7}{s.session_id[:8]}  {age(s.mtime):>4}  {s.cwd()}")


def cmd_latest(args):
    s = resolve_log(args.session, args.agent)
    for t in texts(s, role=args.role, n=args.n):
        print(t)


# ---------- per-host poll (runs locally on every host; uses the library) ----------

def child_map():
    """pid → child pids, from one ps call (per-pane pgrep is too slow on
    the poll's hot path)."""
    kids = {}
    for line in run(["ps", "-eo", "pid=,ppid="]).stdout.splitlines():
        pid, ppid = (int(x) for x in line.split())
        kids.setdefault(ppid, []).append(pid)
    return kids


def descendants(pid, kids):
    seen, stack = [], [pid]
    while stack:
        for k in kids.get(stack.pop(), []):
            seen.append(k)
            stack.append(k)
    return seen


def open_transcript(tree, needle):
    """The transcript a pane's process tree holds open (codex keeps its
    rollout open; claude does not — hence claude's registry gives its id)."""
    for p in tree:
        try:
            entries = os.listdir(f"/proc/{p}/fd")
        except OSError:
            continue
        for fd in entries:
            try:
                target = os.readlink(f"/proc/{p}/fd/{fd}")
            except OSError:
                continue
            if needle in target:
                return target
    return None


def claude_agents():
    """Claude's own registry of running sessions, keyed by pid: the
    authoritative, hook-free source of state + exact session id."""
    r = run(["claude", "agents", "--json"])
    if r.returncode:  # older claude without the command: caller falls back
        return {}
    return {x["pid"]: x for x in json.loads(r.stdout)}


def claude_status(entry):
    """Registry status → fleet state. `state: blocked` is claude's
    needs-input (it pairs with needs:"send a prompt" in jobs/state.json);
    otherwise the running `status` is busy or idle."""
    if entry.get("state") == "blocked":
        return "needs-action"
    status = entry["status"]
    if status == "busy":
        return "working"
    if status == "idle":
        return "waiting"
    sys.exit(f"fleet: unknown claude agent status {status!r}")


def cmd_poll(args):
    """Print this host's agent panes as JSON, state and recency read from
    what each agent exposes about itself. Run locally or over ssh by the
    flagship poll."""
    cmd_agent = {cmd: agent for agent, cmd in AGENT_CMDS.items()}
    agents = claude_agents()
    kids = child_map()
    r = run(["tmux", "list-panes", "-a", "-F", PANE_FMT])
    if r.returncode:
        sys.exit(f"fleet: list-panes: {r.stderr.strip()}")
    rows = []
    for line in r.stdout.splitlines():
        sess, win, widx, pid, ppid, cmd, cwd, title = shlex.split(line)
        agent = cmd_agent.get(cmd)
        if agent is None or "@" in sess:  # non-agent or fleet-created
            continue
        tree = [int(ppid), *descendants(int(ppid), kids)]
        if agent == "claude":
            entry = next((agents[p] for p in tree if p in agents), None)
            if entry:  # the registry: authoritative state + exact session id
                state = claude_status(entry)
                title = entry.get("name") or title
                f = CLAUDE / entry["cwd"].replace("/", "-").replace(".", "-") \
                    / f"{entry['sessionId']}.jsonl"
                ts = int(f.stat().st_mtime) if f.exists() else 0
            else:  # not in the registry: fall back to the pane title glyph
                state = "waiting" if title.startswith("✳") else "working"
                ts = 0
        elif agent == "codex":  # no registry/title; its open rollout carries state
            roll = open_transcript(tree, "rollout-")
            if roll:
                s = session_at("codex", roll)
                state, title = live_state(s)
                ts = int(s.mtime)
            else:
                state, ts = "working", 0
        else:
            sys.exit(f"fleet: no poll reader for agent {agent!r}")
        rows.append(dict(session=sess, win=win, window=int(widx), pane_id=pid,
                         agent=agent, state=state, title=title, cwd=cwd, ts=ts))
    print(json.dumps(rows))


# ---------- the manifest (single writer) ----------

def poll(host):
    """One host's agent panes, via `fleet _poll` run there (the library
    reads each agent's own transcript locally). Returns None when the host
    is unreachable (a failed poll is host-unusable, never "all panes
    died"); a genuine _poll crash surfaces its stderr and is loud."""
    argv = ["fleet", "_poll"] if host == flagship() else ["ssh", host, "fleet _poll"]
    r = run(argv)
    if r.stderr:
        print(r.stderr, end="", file=sys.stderr)
    if r.returncode:
        if r.returncode == 255:  # ssh transport failure
            return None
        sys.exit(f"fleet: _poll on {host} failed: {r.stderr.strip()}")
    return json.loads(r.stdout)


def merge():
    """Agent panes group by host:window_id into rows: urgency wins (a
    working sibling never masks a waiting pane), cwd/title/recency follow
    the urgent pane. enter/scroll keep an exact pane_id only when a row
    holds exactly one agent pane."""
    pane_rows, unreachable = [], []
    for host in hosts():
        got = poll(host)
        if got is None:
            unreachable.append(host)
            continue
        for p in got:
            pane_rows.append(dict(p, host=host))
    rows = {}
    for p in sorted(pane_rows, key=lambda p: p["window"]):
        key = (p["host"], p["win"])
        g = rows.get(key)
        if g is None:
            rows[key] = dict(p, count=1)
            continue
        g["count"] += 1
        g["ts"] = max(g["ts"], p["ts"])  # row recency = newest pane
        g["pane_id"] = None  # ambiguous target: enter/scroll must refuse
        if URGENCY[p["state"]] < URGENCY[g["state"]]:
            g.update(state=p["state"], cwd=p["cwd"], title=p["title"],
                     agent=p["agent"])
    ordered = sorted(rows.values(), key=lambda r: (URGENCY[r["state"]], -r["ts"]))
    return ordered, unreachable


def shadow(win):
    return f"fleet@w{win.lstrip('@')}"


def reconcile(rows, unreachable):
    """Make fleet@main's windows mirror the manifest: one window per row —
    linked for flagship rows, an ssh client onto a ship-side shadow for
    remote rows — with @fleet_* options restamped. Window order IS the
    muster order: pennant number = window index = position in the
    (urgency, newest-change) sort, recomputed at cadence, meaningful only
    as currently displayed. Reordering pauses while any client holds the
    conn key-table (the ring never shifts under fingers). Poll-cadence
    work, off every keypress path. Windows of unreachable hosts are never
    killed (a failed poll is host-unusable, never "all rows died"); they
    sink below the live rows, visibly stale."""
    fs = "fleet@main"
    cur = tmux(flagship(), "display", "-p", "-t", f"={fs}:",
               "#{window_id}").strip()
    have = {}
    # @fleet_src: the remote build record, written once at creation; local rows carry none
    for line in tmux(flagship(), "list-windows", "-t", f"={fs}", "-F",
                     "#{window_index} #{q:window_id} #{q:@fleet_host} "
                     "#{q:@fleet_win} #{q:@fleet_src}").splitlines():
        parts = shlex.split(line)
        if parts[0] == "0":
            continue  # the muster window
        if len(parts) < 4:
            sys.exit(f"fleet: unstamped window {fs}:{parts[0]} — not fleet's, refusing to own it")
        key = (parts[2], parts[3])
        if key in have:
            sys.exit(f"fleet: windows {fs}:{have[key]['idx']} and {fs}:{parts[0]} "
                     f"both claim {parts[2]}:{parts[3]}")
        have[key] = dict(idx=parts[0], wid=parts[1],
                         src=parts[4] if len(parts) > 4 else "")
    want = {(r["host"], r["win"]): r for r in rows}
    # dead rows and migrated shadows: kill and recreate
    doomed_shadows = {}
    for (host, win), w in list(have.items()):
        r = want.get((host, win))
        src_ok = r is not None and (w["src"] == "" if r["host"] == flagship()
                                    else w["src"] == r["session"])
        if src_ok:
            continue
        if host in unreachable:
            continue  # a failed poll is host-unusable, never "all rows died"
        if host == flagship():
            tmux(flagship(), "unlink-window", "-t", f"={fs}:{w['idx']}")
        else:
            tmux(flagship(), "kill-window", "-t", f"={fs}:{w['idx']}")
            if r is None or w["src"] != r["session"]:  # dead or migrated
                doomed_shadows.setdefault(host, []).append(shadow(win))
        del have[(host, win)]
    for host, names in doomed_shadows.items():
        if sh(host, "; ".join(f"tmux kill-session -t {shlex.quote('=' + n)}"
                              for n in names)).returncode:
            sys.exit(f"fleet: shadow cleanup on {host} failed")
    frozen = "fleet" in tmux(flagship(), "list-clients", "-F",
                             "#{client_key_table}").split()
    n, stale_num = 0, {}
    if frozen:
        n = max((int(w["idx"]) for w in have.values()), default=0)
        for r in rows:
            w = have.get((r["host"], r["win"]))
            r["num"] = int(w["idx"]) if w else (n := n + 1)
        for k in set(have) - set(want):
            stale_num[k] = int(have[k]["idx"])
    else:
        order = {}
        for r in rows:
            n += 1
            order[(r["host"], r["win"])] = r["num"] = n
        for k in sorted(set(have) - set(want), key=lambda k: int(have[k]["idx"])):
            n += 1
            order[k] = stale_num[k] = n
        # two-phase: step aside then land, so indices never collide.
        # -d keeps a move from becoming current (man: as link-window),
        # except the viewed window itself, whose landing must select it
        moves, land = [], []
        for k, num in order.items():
            w = have.get(k)
            if w and int(w["idx"]) != num:
                d = [] if w["wid"] == cur else ["-d"]
                moves.append(["move-window", *d, "-s", f"{fs}:{w['idx']}",
                              "-t", f"{fs}:{1000 + num}"])
                land.append(["move-window", *d, "-s", f"{fs}:{1000 + num}",
                             "-t", f"{fs}:{num}"])
        if moves:
            tmux_batched(flagship(), moves + land)
    for (host, win), r in want.items():
        if (host, win) in have:
            continue
        # identity stamps ride the creation: no window survives half-stamped
        ident = ["set-option", "-w", "-t", f"{fs}:{r['num']}", "@fleet_host", host,
                 ";", "set-option", "-w", "-t", f"{fs}:{r['num']}", "@fleet_win", win]
        if host == flagship():
            tmux(flagship(), "link-window", "-d", "-s", win, "-t", f"={fs}:{r['num']}",
                 ";", *ident)
        else:
            # sh, not the login shell: zsh =word expansion eats exact targets
            attach = (f"exec tmux -u new -A -t {shlex.quote('=' + r['session'])} "
                      f"-s {shlex.quote(shadow(win))} \\; select-window -t {win}")
            tmux(flagship(), "new-window", "-d", "-t", f"={fs}:{r['num']}",
                 "-n", r["session"],
                 f"exec ssh -t {shlex.quote(host)} "
                 + shlex.quote("exec sh -c " + shlex.quote(attach)),
                 ";", *ident,
                 ";", "set-option", "-w", "-t", f"{fs}:{r['num']}",
                 "@fleet_src", r["session"])
    stamps = []
    for r in rows:
        for opt, val in dict(host=r["host"], win=r["win"], state=r["state"],
                             num=str(r["num"]), cwd=Path(r["cwd"]).name,
                             name=f"{r['session']}:{r['window']}",
                             title=r["title"], stale="").items():
            stamps.append(["set-option", "-w", "-t", f"{fs}:{r['num']}",
                           f"@fleet_{opt}", val])
    for k, num in stale_num.items():
        stamps.append(["set-option", "-w", "-t", f"{fs}:{num}",
                       "@fleet_stale", "1"])
        stamps.append(["set-option", "-w", "-t", f"{fs}:{num}",
                       "@fleet_num", str(num)])
    if stamps:
        tmux_batched(flagship(), stamps)


def snapshot_write():
    rows, unreachable = merge()
    reconcile(rows, unreachable)
    snap = dict(snapshot_ts=int(time.time()), rows=rows, unreachable=unreachable)
    write_atomic(CACHE / "state.json", json.dumps(snap))
    muster_push("reload(fleet muster --rows)")
    return snap


def need_snapshot():
    f = CACHE / "state.json"
    if not f.exists():
        sys.exit("fleet: no manifest — is the writer muster running?")
    return json.loads(f.read_text())


# ---------- muster (the roll call; watch owns refresh, tmux owns the rest) ----------

COLOR = {"needs-action": "\033[1;31m", "waiting": "\033[33m", "working": "\033[32m"}
LABEL = {"needs-action": "ACTION", "waiting": "WAITING", "working": "WORKING"}


def cmd_muster(args):
    if args.write:
        CACHE.mkdir(parents=True, exist_ok=True)
        lock = (CACHE / "write.lock").open("w")
        try:  # the single-writer invariant is the OS primitive, not convention
            fcntl.flock(lock, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            sys.exit("fleet: another writer holds write.lock")
        snap = snapshot_write()
    else:
        snap = need_snapshot()
    if args.rows:
        return muster_rows(snap)
    c = (lambda code, s: f"{code}{s}\033[0m") if args.color else (lambda code, s: s)
    # an absent fleet session is a normal pre-up state, not an error
    cur = ()
    probe = run(["tmux", "display", "-p", "-t", "=fleet@main:",
                 "#{q:@fleet_host} #{q:@fleet_win}"])
    if probe.returncode == 0:
        cur = tuple(shlex.split(probe.stdout))
    elif "can't find" not in probe.stderr:
        sys.exit(f"fleet: tmux display fleet@main: {probe.stderr.strip()}")
    out = []
    age = int(time.time()) - snap["snapshot_ts"]
    if age > CADENCE:
        out.append(c("\033[2m", f"age {age}s"))
    for host in snap["unreachable"]:
        out.append(c("\033[1;31m", f"{host} unreachable"))
    group = None
    for r in snap["rows"]:
        if r["state"] != group:
            group = r["state"]
            bar = "━" * (26 - len(LABEL[group]))
            out.append(c(COLOR[group], f"━ {LABEL[group]} {bar}"))
        name = f"{r['session']}:{r['window']}"
        if r["count"] > 1:
            name += f"×{r['count']}"
        body = f"{r['num']:>3} {name[:15]:<15} {r['host'][:8]:>8}"
        out.append(c("\033[7m", body) if (r["host"], r["win"]) == cur else body)
    print("\n".join(out))


def muster_rows(snap):
    """fzf input for the muster column: host, window id, pennant, display.
    The first line is the last-update stamp (fzf --header-lines=1), so a
    frozen clock means a dead writer."""
    from collections import Counter
    out = [f"-\t-\t-\t\033[2m{time.strftime('%H:%M:%S', time.localtime(snap['snapshot_ts']))}\033[0m"]
    for host in snap["unreachable"]:
        out.append(f"{host}\t-\t-\t\033[1;31m{host} unreachable\033[0m")
    rows = snap["rows"]
    per_sess = Counter((r["host"], r["session"]) for r in rows)
    names = [(r["session"] if per_sess[(r["host"], r["session"])] == 1
              else f"{r['session']}:{r['window']}")
             + (f"×{r['count']}" if r["count"] > 1 else "") for r in rows]
    wn = max((len(n) for n in names), default=0)
    short = {"claude": "C", "codex": "X"}
    wc = max((len(Path(r["cwd"]).name) for r in rows), default=0)
    for r, name in zip(rows, names):
        line = (f"{COLOR[r['state']]}{name:<{wn + 2}}\033[0m"
                f"\033[2m{short[r['agent']]} {r['host'][0].upper()} "
                f"{Path(r['cwd']).name:<{wc + 1}}\033[0m{r['title']}")
        out.append(f"{r['host']}\t{r['win']}\t{r['num']}\t{line}")
    print("\n".join(out))


def cmd_muster_ui(args):
    """The muster column: one persistent fzf. Rows come from muster_rows;
    the poller and the fleet's after-select-window hook push to the listen
    socket (reload keeps the cursor's screen position — verified — so a
    sunk row leaves the cursor on whatever slides into its place)."""
    import secrets
    kf = muster_key()
    kf.write_text(f"x-api-key: {secrets.token_hex(16)}")
    kf.chmod(0o600)
    env = dict(os.environ, FZF_API_KEY=kf.read_text().split(": ", 1)[1])
    os.execvpe("fzf", [
        "fzf", "--listen", MUSTER_ADDR, "--ansi", "--no-input",
        "--layout", "reverse", "--delimiter", "\t", "--with-nth", "4..",
        "--header-lines", "1", "--info", "hidden", "--no-scrollbar",
        "--preview", "fleet peek {1} {2} | tail -n $FZF_PREVIEW_LINES",
        "--preview-window", "down,50%,border-top",
        "--bind", "start:reload(fleet muster --rows)",
        "--bind", "j:down,k:up,u:first,q:ignore",
        "--bind", "c:execute(fleet create)",
        "--bind", "enter:execute-silent(tmux select-window -t '=fleet@main:{3}' "
                   "&& fleet conn --screen main --arm)",
    ], env)


def cmd_create(args):
    """Interactive from the muster (c): host, agent, directory, name — each
    an fzf pick over the registered options with the first on top, so four
    Enters accept the flagship, the first-listed agent, ~, and its
    basename. One session, one window, one agent."""
    def pick(opts, prompt):
        r = run(["fzf", "--prompt", prompt, "--layout", "reverse"],
                input=opts, capture_output=False, stdout=subprocess.PIPE)
        if r.returncode:
            sys.exit("fleet: create cancelled")
        return r.stdout.strip()
    host = pick("\n".join(hosts()), "host> ")
    agent = pick("\n".join(AGENT_CMDS), "agent> ")
    dirs = sh(host, 'echo "$HOME"; find "$HOME" -maxdepth 3 -type d '
                    '! -path "*/.*" 2>/dev/null | tail -n +2 | sort')
    cwd = pick(dirs.stdout, "dir> ")
    default = Path(cwd).name
    r = run(["fzf", "--print-query", "--prompt", f"name> ", "--layout", "reverse"],
            input=default, capture_output=False, stdout=subprocess.PIPE)
    lines = r.stdout.splitlines()
    name = (lines[-1] if lines else default).strip() or default
    if not NAME_RE.match(name):
        sys.exit(f"fleet: session names are [A-Za-z0-9_-]+, got {name!r}")
    tmux(host, "new-session", "-d", "-s", name, "-c", cwd, agent)
    # bounded startup handshake: the poller musters it within two cadences
    for _ in range(4):
        time.sleep(CADENCE)
        for line in tmux(flagship(), "list-windows", "-t", "=fleet@main", "-F",
                         "#{window_index} #{q:@fleet_host} #{q:@fleet_name}").splitlines():
            parts = shlex.split(line)
            if len(parts) == 3 and parts[1] == host and parts[2].split(":")[0] == name:
                tmux(flagship(), "select-window", "-t", f"=fleet@main:{parts[0]}")
                return
    sys.exit(f"fleet: {name} on {host} was created but never mustered")


def cmd_peek(args):
    print(tmux(args.host, "capture-pane", "-ep", "-t", args.win), end="")


# ---------- fleet up (build the fleet session; owns no rows) ----------

def cmd_up(args):
    """Exactly four things: create =fleet@<screen> if absent, set its
    session-scoped options, create window 0 (the muster watch) if absent,
    exit. A dead watch closes its window, so death is re-created here;
    row windows belong to the poller — no repair loops, no choreography."""
    screen = check_screen(args.screen)
    fs = f"fleet@{screen}"
    watch = "watch -t -c fleet muster --color --write"
    if absent(fs):
        if screen == "main":
            tmux(flagship(), "new-session", "-d", "-s", fs, "-n", "muster", watch)
        else:  # grouped screens share fleet@main's windows (and its one writer)
            if absent("fleet@main"):
                sys.exit("fleet: fleet@main is not up — run: fleet up --screen main")
            tmux(flagship(), "new-session", "-d", "-t", "fleet@main", "-s", fs)
    # set-option rejects =exact targets; plain names are safe (@ is fleet's)
    tmux(flagship(), "set-option", "-t", fs, "renumber-windows", "off")
    tmux(flagship(), "set-option", "-t", fs, "status-right",
         "#{?#{==:#{client_key_table},fleet},#[fg=magenta bold]-- CONN -- #[default],}"
         "#[fg=color3]%d %b %R ")
    if screen == "main":
        # selection follows into the muster column's fzf socket (row N =
        # window N; curl failure = no column open, the one named skip)
        curl = ("curl -s -m 1 -H @" + str(muster_key())
                + " -XPOST -d \\\"pos(#{window_index})\\\" "
                + f"http://{MUSTER_ADDR} >/dev/null 2>&1 || true")
        tmux(flagship(), "set-hook", "-t", fs, "after-select-window",
             f"if -F \"#{{window_index}}\" 'run-shell -b \"{curl}\"'")
    if not any(line.startswith("0 ") for line in
               tmux(flagship(), "list-windows", "-t", f"={fs}",
                    "-F", "#{window_index} ").splitlines()):
        tmux(flagship(), "new-window", "-d", "-t", f"={fs}:0", "-n", "muster", watch)
    print(f"{fs} up")


# ---------- the conn (arms the native key-table; motions are pure tmux) ----------

def cmd_conn(args):
    fs = f"fleet@{check_screen(args.screen)}"
    clients = []
    for line in tmux(flagship(), "list-clients", "-F",
                     "#{client_tty} #{client_key_table} #{q:session_name}").splitlines():
        tty, table, sess = shlex.split(line)
        if sess == fs:
            clients.append((tty, table))
    if not clients:
        sys.exit(f"fleet: no client is attached to {fs}")
    if any(table == "fleet" for _, table in clients):  # gear toggles
        if args.arm:  # already armed is what --arm wants: stay
            return
        for tty, _ in clients:
            tmux(flagship(), "switch-client", "-c", tty, "-T", "root")
        return
    origin = tmux(flagship(), "display", "-p", "-t", f"={fs}:", "#{window_id}").strip()
    tmux(flagship(), "set-option", "-t", fs, "@fleet_origin", origin)
    # arm last: switch-client resets a client's key table
    for tty, _ in clients:
        tmux(flagship(), "switch-client", "-c", tty, "-T", "fleet")


# ---------- switching (every verb is one native tmux command) ----------

def resolve(snap, target):
    rows = snap["rows"]
    matches = ([r for r in rows if r["num"] == int(target)] if target.isdigit()
               else [r for r in rows if r["session"] == target])
    if not matches:
        sys.exit(f"fleet: no session matches {target!r}")
    if len(matches) > 1:  # session names are not row keys: refuse ambiguity
        nums = ", ".join(str(r["num"]) for r in matches)
        sys.exit(f"fleet: {target!r} is ambiguous — say a pennant: {nums}")
    return matches[0]

def cmd_switch(args):
    row = resolve(need_snapshot(), args.target)
    tmux(flagship(), "select-window",
         "-t", f"=fleet@{check_screen(args.screen)}:{row['num']}")


def cmd_next(args):
    fs = f"fleet@{check_screen(args.screen)}"
    r = run(["tmux", "next-window", "-a", "-t", f"={fs}"])
    if r.returncode:  # the no-alert wording is verified on 3.6b; anything
        sys.exit("fleet: nothing is unacknowledged"  # else is a real boundary
                 if "no next window" in r.stderr
                 else f"fleet: tmux next-window on {fs}: {r.stderr.strip()}")


def target_pane(args):
    """The exact pane a verb acts on: a named row, or the current fleet
    window's row. Rows holding more than one agent pane refuse — the
    target is ambiguous and refusal beats guessing."""
    snap = need_snapshot()
    if args.target:
        row = resolve(snap, args.target)
    else:
        fs = f"fleet@{check_screen(args.screen)}"
        parts = shlex.split(tmux(flagship(), "display", "-p", "-t", f"={fs}:",
                                 "#{q:@fleet_host} #{q:@fleet_win}"))
        rows = [r for r in snap["rows"]
                if len(parts) == 2 and (r["host"], r["win"]) == tuple(parts)]
        if not rows:
            sys.exit("fleet: the current window is not an agent row")
        row = rows[0]
    if not row["pane_id"]:
        sys.exit(f"fleet: row {row['num']} holds {row['count']} agents — say which")
    return row["host"], row["pane_id"]


def cmd_enter(args):
    host, pid = target_pane(args)
    tmux(host, "send-keys", "-t", pid, "Enter")
    print(f"enter → {host}:{pid}")


def cmd_scroll(args):
    host, pid = target_pane(args)
    tmux(host, "copy-mode", "-e", "-t", pid)
    tmux(host, "send-keys", "-X", "-t", pid, f"halfpage-{args.dir}")


def cmd_rename(args):
    if not NAME_RE.match(args.name):
        sys.exit("fleet: session names are [A-Za-z0-9_-]+ (`@` marks fleet sessions)")
    row = resolve(need_snapshot(), args.target)
    tmux(row["host"], "rename-session", "-t", f"={row['session']}", args.name)


# ---------- say (Tier 2 resolver; callers: wake listener, shell) ----------

WORDS = {w: i for i, w in enumerate(
    "zero one two three four five six seven eight nine ten eleven twelve "
    "thirteen fourteen fifteen sixteen seventeen eighteen nineteen".split())}
WORDS.update({w: 20 + 10 * i for i, w in enumerate(
    ["twenty", "thirty", "forty", "fifty", "sixty", "seventy", "eighty", "ninety"])})


def spoken_number(words):
    """A number only if EVERY word is numeric — 'the one dealing with X'
    must not read as 1."""
    total, seen = 0, False
    for w in words:
        w = w.strip(",.").lower()
        if w.isdigit():
            total, seen = total + int(w), True
        elif w in WORDS:
            total, seen = total + WORDS[w], True
        else:
            return None
    return total if seen else None


def llm_resolve(utterance, snap):
    import urllib.request
    cfg = CONFIG / "llm"
    if not cfg.exists():
        sys.exit(f"fleet: could not resolve {utterance!r} by rule, and no LLM "
                 f"endpoint is configured ({cfg})")
    base = cfg.read_text().strip()
    try:
        model = json.load(urllib.request.urlopen(f"{base}/models"))["data"][0]["id"]
    except OSError as e:  # the LLM boundary translates failures, loudly
        sys.exit(f"fleet: LLM endpoint {base} unreachable: {e}")
    except (KeyError, IndexError, ValueError) as e:  # incl. JSONDecodeError
        sys.exit(f"fleet: LLM /models response was not understood: {e}")
    rows = [dict(num=r["num"], session=r["session"], state=r["state"],
                 host=r["host"], dir=Path(r["cwd"]).name) for r in snap["rows"]]
    prompt = (
        "You resolve a spoken command against a list of terminal agent sessions. "
        "Reply with STRICT JSON only: "
        '{"action": "switch|scroll_up|scroll_down|next|none", "target": <num or null>} '
        "— optionally \"screen\": \"<name>\" ONLY if the utterance names a screen. "
        "If the reference is ambiguous, return action none. "
        f"Sessions: {json.dumps(rows)}\nUtterance: {utterance!r}")
    req = urllib.request.Request(
        f"{base}/chat/completions",
        json.dumps(dict(model=model, messages=[dict(role="user", content=prompt)])).encode(),
        {"Content-Type": "application/json"})
    try:
        text = json.load(urllib.request.urlopen(req))["choices"][0]["message"]["content"]
        verdict = json.loads(text)
    except OSError as e:
        sys.exit(f"fleet: LLM call failed: {e}")
    except (KeyError, IndexError, ValueError) as e:  # incl. JSONDecodeError
        sys.exit(f"fleet: LLM reply was not understood: {e}")
    if not isinstance(verdict, dict) or verdict.get("action") not in (
            "switch", "scroll_up", "scroll_down", "next", "none"):
        sys.exit(f"fleet: LLM reply was not the verdict schema: {verdict!r}")
    return verdict


def cmd_say(args):
    args.utterance = " ".join(args.utterance)
    if not args.utterance:
        sys.exit("fleet: nothing to say")
    snap = need_snapshot()
    m = re.match(r"on screen (\S+),? *(.*)", args.utterance, re.I)
    if m:
        spoken = m.group(1).strip(",.").lower()
        args.screen = str(WORDS.get(spoken, spoken))
        args.utterance = m.group(2)
    u = args.utterance.lower().strip(" .")
    if re.fullmatch(r"next( waiting)?", u):
        return cmd_next(args)
    if re.fullmatch(r"(press |hit )?enter( on .*)?|submit", u):
        sys.exit("fleet: spoken submit is disabled until the wake-word dry-run "
                 "chooses its form")
    m = re.fullmatch(r"scroll (up|down)( on (.+))?", u)
    if m:
        args.dir, args.target = m.group(1), None
        if m.group(3):
            n = spoken_number(m.group(3).split())
            args.target = str(n) if n is not None else m.group(3)
        return cmd_scroll(args)
    m = re.fullmatch(r"rename (\S+) to (.+)", u)  # rule-only: free text never reaches the LLM
    if m:
        n = spoken_number([m.group(1)])
        args.target = str(n) if n is not None else m.group(1)
        args.name = "-".join(m.group(2).split())
        return cmd_rename(args)
    m = re.fullmatch(r"(?:switch to |go to )?(?:session |the )?(.+)", u)
    if m:
        n = spoken_number(m.group(1).split())  # whole tail first: "twenty one"
        if n is not None and any(r["num"] == n for r in snap["rows"]):
            args.target = str(n)
            return cmd_switch(args)
        name = re.sub(r" one$", "", m.group(1))  # "the mddb one" -> mddb
        if any(r["session"] == name for r in snap["rows"]):
            args.target = name
            return cmd_switch(args)
    verdict = llm_resolve(args.utterance, snap)
    if verdict.get("screen"):
        args.screen = str(verdict["screen"])
    action = verdict.get("action")
    if action == "switch" and verdict.get("target") is not None:
        args.target = str(verdict["target"])
        return cmd_switch(args)
    if action == "next":
        return cmd_next(args)
    if action in ("scroll_up", "scroll_down"):
        args.dir = action.split("_")[1]
        args.target = (str(verdict["target"])
                       if verdict.get("target") is not None else None)
        return cmd_scroll(args)
    sys.exit(f"fleet: could not resolve {args.utterance!r} (LLM said {verdict})")


# ---------- cli ----------

def main():
    import argparse
    p = argparse.ArgumentParser(prog="fleet")
    sub = p.add_subparsers(dest="cmd", required=True)

    def add(name, fn, *spec):
        sp = sub.add_parser(name)
        sp.set_defaults(fn=fn)
        sp.add_argument("--screen", default="main")
        for names, kw in spec:
            sp.add_argument(*names, **kw)
        return sp

    add("muster", cmd_muster, (["--write"], dict(action="store_true")),
        (["--color"], dict(action="store_true")),
        (["--rows"], dict(action="store_true")))
    add("muster-ui", cmd_muster_ui)
    add("peek", cmd_peek, (["host"], dict()), (["win"], dict()))
    add("up", cmd_up)
    add("conn", cmd_conn, (["--arm"], dict(action="store_true")))
    add("switch", cmd_switch, (["target"], dict()))
    add("next", cmd_next)
    add("enter", cmd_enter, (["target"], dict(nargs="?")))
    add("scroll", cmd_scroll, (["dir"], dict(choices=["up", "down"])),
        (["target"], dict(nargs="?")))
    add("rename", cmd_rename, (["target"], dict()), (["name"], dict()))
    add("create", cmd_create)
    add("_poll", cmd_poll)
    add("list", cmd_list, (["--agent"], dict(choices=["claude", "codex"])),
        (["-n"], dict(type=int, default=20)))
    add("info", cmd_info, (["session"], dict(nargs="?")),
        (["--agent"], dict(choices=["claude", "codex"])))
    add("latest", cmd_latest, (["session"], dict(nargs="?")),
        (["--agent"], dict(choices=["claude", "codex"])),
        (["--role"], dict(default="assistant", choices=["assistant", "user"])),
        (["-n"], dict(type=int, default=1)))
    add("say", cmd_say, (["utterance"], dict(nargs="*")))
    args = p.parse_args()
    args.fn(args)


if __name__ == "__main__":
    main()
