    awin = tmux(flagship(), "display", "-p", "-t", f"={a}:", "#{window_id}").strip()
    bwin = tmux(flagship(), "display", "-p", "-t", f"={b}:", "#{window_id}").strip()
    tmux(flagship(), "select-window", "-t", f"={a}:{bwin}", ";",
         "select-window", "-t", f"={b}:{awin}")


