def cmd_create(args):
    def pick(opts, prompt):
        r = run(["fzf", "--prompt", prompt, "--layout", "reverse"],
                input=opts, capture_output=False, stdout=subprocess.PIPE)
        if r.returncode:
            sys.exit("fleet: create cancelled")
        return r.stdout.strip()
    host = pick("\n".join(hosts()), "host> ")
    agent = pick("\n".join(AGENT_CMDS), "agent> ")
    dirs = sh(host, 'echo "$HOME"; find "$HOME" -maxdepth 3 -type d '
                    '! -path "*/.*" 2>/dev/null | tail -n +2 | sort')
    cwd = pick(dirs.stdout, "dir> ")
    default = Path(cwd).name
    r = run(["fzf", "--print-query", "--prompt", "name> ", "--layout", "reverse"],
            input=default, capture_output=False, stdout=subprocess.PIPE)
    lines = r.stdout.splitlines()
    name = (lines[-1] if lines else default).strip() or default
    if not NAME_RE.match(name):
        sys.exit(f"fleet: session names are [A-Za-z0-9_-]+, got {name!r}")
    tmux(host, "new-session", "-d", "-s", name, "-c", cwd, agent)
    for _ in range(4):
        time.sleep(CADENCE)
        for line in tmux(flagship(), "list-windows", "-t", "=fleet@main", "-F",
                         "#{window_index} #{q:@fleet_host} #{q:@fleet_name}").splitlines():
            parts = shlex.split(line)
            if len(parts) == 3 and parts[1] == host and parts[2].split(":")[0] == name:
                tmux(flagship(), "select-window",
                     "-t", f"=fleet@{selected_screen(args)}:{parts[0]}")
                return
    sys.exit(f"fleet: {name} on {host} was created but never mustered")


def cmd_peek(args):
    print(tmux(args.host, "capture-pane", "-ep", "-t", args.win), end="")


def cmd_up(args):
    screen = check_screen(args.screen or "main")
    fs = f"fleet@{screen}"
    watch = (f"env SSH_AUTH_SOCK={shlex.quote(str(SSH_AGENT_SOCKET))} "
             "watch -t -c fleet muster --color --write")
    if absent(flagship(), fs):
        if screen == "main":
            tmux(flagship(), "new-session", "-d", "-s", fs, "-n", "muster", watch)
        else:
            if absent(flagship(), "fleet@main"):
                sys.exit("fleet: fleet@main is not up — run: fleet up --screen main")
            tmux(flagship(), "new-session", "-d", "-t", "fleet@main", "-s", fs)
    tmux(flagship(), "set-option", "-t", fs, "renumber-windows", "off")
    tmux(flagship(), "set-option", "-t", fs, "status-right",
         "#{?#{==:#{client_key_table},fleet},#[fg=magenta bold]-- CONN -- #[default],}"
         "#{?#{==:#{session_name},fleet@#{@fleet_focused_station}},#[fg=cyan]● #[default],}"
         "#[fg=color3]%d %b %R ")
    curl = (f"curl -s --max-time .2 --unix-socket {shlex.quote(str(MUSTER_SOCKET))} "
            "-XPOST -d \\\"pos(#{window_index})\\\" http://localhost >/dev/null 2>&1 || :")
    tmux(flagship(), "set-hook", "-t", fs, "after-select-window",
         f"run-shell -b \"{curl}\"")
    tmux(flagship(), "set-hook", "-t", fs, "client-focus-in",
         f"set-option -g @fleet_focused_station {screen} ; run-shell -b \"{curl}\"")
    if not any(line.startswith("0 ") for line in
               tmux(flagship(), "list-windows", "-t", f"={fs}",
                    "-F", "#{window_index} ").splitlines()):
        tmux(flagship(), "new-window", "-d", "-t", f"={fs}:0", "-n", "muster", watch)
    print(f"{fs} up")


def station_session(name):
    name = check_screen(name)
    fs = f"fleet@{name}"
    if absent(flagship(), fs):
        sys.exit(f"fleet: station {name!r} is not up")
    return fs


def stations():
    focused = tmux(flagship(), "show-option", "-gqv", "@fleet_focused_station").strip()
    out = []
    for session in tmux(flagship(), "list-sessions", "-F", "#{session_name}").splitlines():
        if not session.startswith("fleet@") or session == "fleet@muster":
            continue
        screen = session.removeprefix("fleet@")
        fmt = ("index=#{window_index} win=#{q:window_id} name=#{q:@fleet_name} "
               "state=#{q:@fleet_state}")
        line = tmux(flagship(), "display", "-p", "-t", f"={session}:", fmt).strip()
        d = dict(x.partition("=")[::2] for x in shlex.split(line))
        out.append(dict(station=screen, focused=screen == focused,
                        index=int(d["index"]), win=d["win"],
                        name=d["name"], state=d["state"]))
    return sorted(out, key=lambda s: s["station"])


def cmd_station_list(args):
    for station in stations():
        mark = "*" if station["focused"] else " "
        shown = station["name"] or "empty"
        print(f"{mark} {station['station']:<16} {station['index']:>3}  {shown}")


def cmd_station_focus(args):
