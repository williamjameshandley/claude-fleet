#!/bin/sh
if [ "$(hostname -s)" != lovelace ]; then
    exec ssh -tt -o BatchMode=yes lovelace fleet-commander "$@"
fi
id=$(jq -r 'select(.thread_name == "commander") | .id' \
    /home/will/.codex/session_index.jsonl | tail -n 1)
command="cd /home/will && exec codex --sandbox danger-full-access resume $id"
if [ "$1" = restart ] && tmux has-session -t fleet@commander 2>/dev/null; then
    tmux respawn-pane -k -t fleet@commander:0.0 "$command"
fi
exec tmux -u new-session -A -s fleet@commander "$command"
